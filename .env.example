# OB-Nucleus environment template. Copy to .env or set via setx (preferred on Windows).
# Real values live in environment variables only. Never commit a real token.

# Audity read-only PAT (active token for all reads). Format: aky_ + 32 chars.
AUDITY_TOKEN=aky_your_read_token_here

# Audity read+write PAT. GATED: used only for writes Chris explicitly approves.
# Leave unset in normal operation.
# AUDITY_WRITE_TOKEN=aky_your_write_token_here

# Supabase BlueprintOS mirror target (optional; mirror falls back to SQLite only).
OBN_SUPABASE_URL=https://mjbbpzwyamymboazabmx.supabase.co
OBN_SUPABASE_SERVICE_KEY=your_service_role_key_here
